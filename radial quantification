if not exists(join(directory, f"{ovary_name}.vti")):
    printc("Resampling the volume: ", f"{ovary_name}.vti", c="y", italic=True)
    vol = Volume(join(directory, f"{ovary_name}.tif"))
    vol.spacing(spacing)
    sx, sy, sz = vol.dimensions()
    vol.resize([int(sx / 4), int(sy / 4), sz])
    vol.write(join(directory, f"{ovary_name}.vti"))
else:
    printc("Volume already resampled: ", f"{ovary_name}.vti", c="g", italic=True)


if not exists(join(directory, f"{ovary_name}_smoothed.vti")):
    printc("Smoothing the volume: ", f"{ovary_name}_smoothed.vti", c="y", italic=True)
    svol = Volume(join(directory, f"{ovary_name}.vti"))
    if smoothing:
        svol.smooth_gaussian(smoothing)
        svol.write(join(directory, f"{ovary_name}_smoothed.vti"))
else:
    printc("Volume already smoothed: ", f"{ovary_name}_smoothed.vti", c="g", italic=True)
    svol = Volume(join(directory, f"{ovary_name}_smoothed.vti"))


if not exists(join(directory, f"{ovary_name}_smoothed_surf.vtk")):
    printc("Computing isosurface: ", f"{ovary_name}_smoothed_surf.vtk", c="y", italic=True)
    surface = svol.isosurface(isovalue).decimate(0.02).smooth()
    surface.write(join(directory, f"{ovary_name}_smoothed_surf.vtk"))
else:
    printc("Isosurface already computed: ", f"{ovary_name}_smoothed_surf.vtk", c="g", italic=True)
    surface = Mesh(join(directory, f"{ovary_name}_smoothed_surf.vtk"))



