def onpick(w=None, e="", flip=1):
    np.save(join(directory, f"{ovary_name}_nodes.npy"), sptool.nodes())
    respline = Spline(sptool.spline(), res=100)  # respline
    pts = respline.vertices
    tangents = respline.tangents()
    fplane = fit_plane(pts).alpha(0.1).lighting("off")
    pnormal = fplane.normal


    data, lines, signs = [], [], []
    for i, p in enumerate(centers):
        r = sizes[i]
        if not (R1 < r < R2):  ###raggio in um
            continue
        iq = respline.closest_point(p, return_point_id=True)
        v = np.cross(tangents[iq], p - pts[iq])
        s = np.dot(v, pnormal)
        signs.append(s)
        data.append([iq, r])
        lines.append([pts[iq], p])
    data = np.array(data)
    lines = np.array(lines)
    signs = np.sign(signs)


    # flip plane normal if most points are below the plane
    if np.sum(signs) > 0:
        pnormal *= -1
    pnormal *= flip  # flip plane normal if needed manually


    nlines, vlabels, angles, radii, iqs = [], [], [], [], []
    for i, d in enumerate(data):
        iq = int(d[0])  ##numero lungo lo spline
        p = pts[iq]
        r = d[1]
        t = tangents[iq]
        ovocite = lines[i][1]
        ovo = (ovocite - p) / mag(ovocite - p)
        n = np.cross(t, pnormal)
        nlines.append([p, p + 50 * n])
        # find angle between ovo and n
        angle = np.arccos(np.dot(n, ovo))
        if np.dot(pnormal, ovo) < 0:
            angle = 2 * np.pi - angle
        tx = Text3D(f"{angle*57.3:.0f}°", pos=ovocite, s=8, justify="center")
        vlabels.append(tx)
        angles.append(angle)
        radii.append(r)
        iqs.append(iq)


    df = pd.DataFrame()
    df["angle"] = angles
    df["radius"] = radii
    df["position_along_spline"] = iqs
    df.to_excel(join(directory, f"{ovary_name}.xlsx"))


    angles = np.array(angles)
    vlines = Lines(nlines, lw=3).c("green5")
    olines = Lines(lines).c("gray", 0.25)
    labels = respline.labels("id", scale=5)


    # plot histograms and 2D polar plot
    histo_size = histogram(
        data[:, 1], xtitle="oocyte sizes", ytitle="", title=" ", aspect=2
    ).clone2d(size=0.75)
    histo_spline = histogram(
        data[:, 0],
        xtitle="density along spline",
        ytitle="",
        title=" ",
        aspect=2,
        c="red5",
    ).clone2d("bottom-right", 0.75)
    histo_2d = histogram(
        angles + np.pi / 2,
        mode="polar",
        bins=8,  # rotate 90°
        cmap="viridis_r",
        show_errors=1,
        show_lines=1,
    )


    on0 = [olines, respline, fplane, vlines, labels, *vlabels]
    on1 = [histo_size, histo_spline, histo_2d]
    for o in on0 + on1:
        o.name = "onpick"
    plt.at(0).remove("onpick").add(on0)
    plt.at(1).remove("onpick").add(on1)
    plt.reset_camera().render()




def onbutton(event):
    if event.keypress == "f":
        onpick(flip=-1)  # flip the plane normal and recompute




